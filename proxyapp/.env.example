# Local development environment
DJANGO_SECRET_KEY=local-dev-secret-key
DJANGO_DEBUG=True

# Optional: public URL used in quick route UI
# EZPROXY_PUBLIC_SITE_HOST=http://127.0.0.1:8000

# Optional: control outbound TLS verification for target sites
# EZPROXY_TLS_VERIFY=true
# EZPROXY_CA_BUNDLE=/absolute/path/to/ca-bundle.pem
